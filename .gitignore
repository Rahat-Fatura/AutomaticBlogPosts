# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# scraper output
/scraper/output/
test-*.js

# prisma


# docker
# docker-compose.yml (commented out to allow committing)

# WordPress - exclude dynamic content only
/wordpress/wp-content/uploads/
/wordpress/wp-content/cache/
/wordpress/wp-content/upgrade/
/wordpress/wp-content/upgrade-temp-backup/
/wordpress/wp-content/backup*/
/wordpress/wp-content/backups/
/wordpress/wp-content/ai1wm-backups/

# WordPress core files (will be managed by Docker)
/wordpress/wp-admin/
/wordpress/wp-includes/
/wordpress/*.php
/wordpress/license.txt
/wordpress/readme.html
/wordpress/.htaccess
/wordpress/wp-config.php
wordpress_backup.sql
